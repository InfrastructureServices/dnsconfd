summary: Run unit tests
execute:
    how: tmt
    script: pytest -vv unittests/
prepare:
  - name: packages
    order: 1
    how: install
    package:
      - python3-pytest
      - python3-pyyaml
      - python3-dbus
      - python3-gobject-base
      - python3-systemd
adjust:
  when: trigger is not defined or trigger == human
  provision:
    how: virtual
    image: fedora-rawhide
